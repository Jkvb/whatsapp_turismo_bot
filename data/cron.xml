<odoo>
    <record id="ir_cron_cleanup_old_whatsapp_sessions" model="ir.cron">
        <field name="name">Cleanup completed WhatsApp sessions</field>
        <field name="model_id" ref="model_whatsapp_bot_session"/>
        <field name="state">code</field>
        <field name="code">model.search([('state', '=', 'completed'), ('active', '=', True)]).write({'active': False})</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
