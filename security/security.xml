<odoo>
    <record id="group_tourism_admin" model="res.groups">
        <field name="name">Administrador de Turismo</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="group_tourism_reviewer" model="res.groups">
        <field name="name">Revisor de Turismo</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_tourism_portal_user" model="res.groups">
        <field name="name">Usuario Portal Turismo</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="tourism_provider_rule_portal_own" model="ir.rule">
        <field name="name">Tourism Provider Portal Own</field>
        <field name="model_id" ref="model_tourism_provider"/>
        <field name="groups" eval="[(4, ref('whatsapp_turismo_bot.group_tourism_portal_user'))]"/>
        <field name="domain_force">[('portal_user_id', '=', user.id)]</field>
    </record>

    <record id="tourism_post_rule_portal_own" model="ir.rule">
        <field name="name">Tourism Post Portal Own</field>
        <field name="model_id" ref="model_tourism_post"/>
        <field name="groups" eval="[(4, ref('whatsapp_turismo_bot.group_tourism_portal_user'))]"/>
        <field name="domain_force">[('provider_id.portal_user_id', '=', user.id)]</field>
    </record>

    <record id="tourism_post_rule_public_published" model="ir.rule">
        <field name="name">Tourism Post Public Published</field>
        <field name="model_id" ref="model_tourism_post"/>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="domain_force">[('state', '=', 'published'), ('provider_id.approval_state', '=', 'approved')]</field>
    </record>
</odoo>
